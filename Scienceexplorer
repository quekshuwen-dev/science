 steps:['Light travels in STRAIGHT LINES. Hits OPAQUE object → cannot pass through.','Shadow forms BEHIND object. Same shape as the object.','Torch CLOSE → big blurry shadow. Torch FAR → small sharp shadow. Sun low in sky → long shadow!'],
 L:{em:'🔦🧱',t:'Torch CLOSE',b:'Shadow = BIG 📐<br/>Shadow = BLURRY 🌫️'},R:{em:'🌞',t:'Sun HIGH at noon',b:'Shadow = SHORT<br/>Directly under you'},
 fun:'At sunrise your shadow can be as long as a whole building! By noon it almost disappears!',tip:'Close = BIG blurry. Far = small sharp. High sun = short shadow. Low sun = long shadow!'}
];

/* ── APP STATE ── */
var selLvl=null,selTopic=null,progress={},notes=[],uploads=[],lastTxt='';

function sw(n){
  document.querySelectorAll('.tb').forEach(function(b){b.classList.remove('on');});
  document.querySelectorAll('.tc').forEach(function(c){c.classList.remove('on');});
  document.querySelector('[onclick="sw(\''+n+'\')"]').classList.add('on');
  document.getElementById('t'+n).classList.add('on');
  if(n==='stars')renderStars();
  if(n==='notes')renderNotes();
}

function buildLvls(){
  var r=document.getElementById('lvlRow');
  ['P3','P4','P5','P6'].forEach(function(l){
    var b=document.createElement('button');
    b.className='lvl-btn';b.textContent=l;
    b.onclick=function(){
      selLvl=l;selTopic=null;
      document.querySelectorAll('.lvl-btn').forEach(function(x){x.classList.remove('on');});
      b.classList.add('on');
      buildTopics(l);
      document.getElementById('topSec').style.display='block';
      document.getElementById('goBtn').disabled=true;
      document.getElementById('lessonOut').innerHTML='';
    };
    r.appendChild(b);
  });
}

function buildTopics(l){
  var g=document.getElementById('topGrid');g.innerHTML='';
  SYL[l].forEach(function(t){
    var c=document.createElement('div');c.className='topic-card';
    c.innerHTML='<span class="t-em">'+t.em+'</span><div class="t-nm">'+t.lbl+'</div>';
    c.onclick=function(){
      selTopic=t;
      document.querySelectorAll('.topic-card').forEach(function(x){x.classList.remove('on');});
      c.classList.add('on');
      document.getElementById('goBtn').disabled=false;
    };
    g.appendChild(c);
  });
}

function showLesson(){
  if(!selTopic)return;
  var t=selTopic;
  if(!progress[selLvl])progress[selLvl]=[];
  if(!progress[selLvl].includes(t.lbl))progress[selLvl].push(t.lbl);
  lastTxt=selLvl+': '+t.lbl;
  if(L[t.id]){document.getElementById('lessonOut').innerHTML=L[t.id]();}
  else{document.getElementById('lessonOut').innerHTML='<div class="emp"><div class="ee">🚧</div><div class="et">Coming soon!</div></div>';}
}

function buildChips(){
  var el=document.getElementById('chips');
  QA.forEach(function(d){
    var c=document.createElement('span');c.className='chip';c.textContent=d.q;
    c.onclick=function(){document.getElementById('qin').value=d.q;doAsk();};
    el.appendChild(c);
  });
}

function doAsk(){
  var q=document.getElementById('qin').value.trim();if(!q)return;
  document.getElementById('qin').value='';
  var kw=q.toLowerCase(),best=null;
  if(kw.includes('weight')||kw.includes('mass')||kw.includes('moon'))best=QA[0];
  else if(kw.includes('photo')||kw.includes('glucose')||kw.includes('leaf')||kw.includes('plant food'))best=QA[1];
  else if(kw.includes('water cycle')||kw.includes('rain')||kw.includes('evapor')||kw.includes('cloud'))best=QA[2];
  else if(kw.includes('conduct')||kw.includes('insul'))best=QA[3];
  else if(kw.includes('magnet')||kw.includes('pole')||kw.includes('attract')||kw.includes('repel'))best=QA[4];
  else if(kw.includes('shadow')||kw.includes('opaque'))best=QA[5];
  var ex=QA.find(function(d){return d.q.toLowerCase()===kw;});if(ex)best=ex;
  if(best){renderQA(q,best);return;}
  document.getElementById('qaOut').innerHTML='<div class="banner bg"><span class="b-em">🤔</span><div class="b-lbl">Hmm!</div><div class="b-txt">Try one of the topic chips above, or go to Learn and pick the topic!</div></div>';
}

function renderQA(q,d){
  var steps=d.steps.map(function(s,i){return'<div class="sr"><div class="sn">'+(i+1)+'</div><div><div class="st3">'+s+'</div></div></div>';}).join('');
  document.getElementById('qaOut').innerHTML=
    '<div class="banner bp"><span class="b-em">💬</span><div class="b-lbl">Answer!</div><div class="b-txt">'+d.a+'</div></div>'+
    CMP(d.L,d.R)+
    MEM('🔑',d.fun,'#E1F5EE','#0F8C63','#0A5C41')+
    '<div class="stitle">📋 Step by step</div>'+
    '<div class="steps">'+steps+'</div>'+
    MEM('🧠',d.tip);
}

function onFile(e){var f=e.target.files[0];if(f)processFile(f);}
function processFile(file){
  if(file.size>5*1024*1024){toast('File too big!');return;}
  var r=new FileReader(),isImg=file.type.startsWith('image/');
  if(isImg){r.onload=function(e){uploads.push({name:file.name,type:'image',data:e.target.result});renderFiles();};r.readAsDataURL(file);}
  else{r.onload=function(e){uploads.push({name:file.name,type:'text',data:e.target.result});renderFiles();};r.readAsText(file);}
}
function renderFiles(){
  var fl=document.getElementById('fList');fl.innerHTML='';
  uploads.forEach(function(f,i){
    var d=document.createElement('div');
    d.style.cssText='display:flex;align-items:center;gap:9px;padding:9px 12px;background:#f8f6ff;border-radius:11px;margin-bottom:6px;border:2.5px solid #e8e4ff';
    d.innerHTML='<span style="font-size:20px">'+(f.type==='image'?'🖼️':'📄')+'</span><span style="flex:1;font-size:11px;font-weight:900;color:#333">'+f.name+'</span><button style="padding:4px 10px;border-radius:8px;border:2px solid #d5ceff;background:#fff;font-size:11px;font-weight:900;cursor:pointer;color:#aaa" onclick="uploads.splice('+i+',1);renderFiles()">✕</button>';
    fl.appendChild(d);
  });
  var fp=document.getElementById('fPreview'),fc=document.getElementById('fContent');
  if(!uploads.length){fp.style.display='none';return;}
  fp.style.display='block';fc.innerHTML='';
  uploads.forEach(function(f){
    var card=document.createElement('div');card.className='nc';
    if(f.type==='image')card.innerHTML='<div class="nt"><span class="ntl">🖼️ '+f.name+'</span></div><img src="'+f.data+'" style="width:100%;border-radius:10px;margin-top:6px"/>';
    else card.innerHTML='<div class="nt"><span class="ntl">📄 '+f.name+'</span></div><div class="nb">'+f.data.slice(0,200).replace(/</g,'&lt;')+'...</div>';
    fc.appendChild(card);
  });
}
function saveNote(){
  var content=document.getElementById('nta').value.trim();
  if(!content){toast('Write something first!');return;}
  notes.push({content:content,lvl:document.getElementById('nLvl').value.trim(),topic:document.getElementById('nTopic').value.trim(),time:new Date().toLocaleTimeString()});
  document.getElementById('nta').value='';document.getElementById('nLvl').value='';document.getElementById('nTopic').value='';
  renderNotes();toast('Saved! ✅');
}
function renderNotes(){
  var el=document.getElementById('nList');
  if(!notes.length){el.innerHTML='<div class="emp" style="padding:14px 0"><div class="ee" style="font-size:36px">📝</div><div class="et" style="font-size:12px">No notes yet!</div></div>';return;}
  el.innerHTML=notes.map(function(n,i){
    return'<div class="nc"><div class="nt"><span class="ntl">'+(n.lvl?'<span style="background:#ede9ff;color:#5B4FCF;padding:2px 7px;border-radius:7px;font-size:9px;margin-right:4px">'+n.lvl+'</span>':'')+''+(n.topic||'Note')+'</span><button class="nd" onclick="notes.splice('+i+',1);renderNotes()">✕</button></div><div class="nb">'+n.content.slice(0,150)+(n.content.length>150?'...':'')+'</div><div style="font-size:9px;font-weight:800;color:#ccc;margin-top:4px">'+n.time+'</div></div>';
  }).join('');
}
function copyLesson(){
  if(!lastTxt){toast('Open a lesson first!');return;}
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(lastTxt).then(function(){toast('Copied! 📋');});}
  else{var ta=document.createElement('textarea');ta.value=lastTxt;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);toast('Copied! 📋');}
}
function exportNotes(){
  if(!notes.length){toast('No notes yet!');return;}
  var txt='MY SCIENCE NOTES\n\n'+notes.map(function(n,i){return'['+(i+1)+'] '+(n.lvl?n.lvl+' ':'')+''+(n.topic||'Note')+'\n'+n.content;}).join('\n\n---\n\n');
  dlFile(txt,'MyNotes.txt');toast('Downloaded! ✅');
}
function exportStars(){
  var lvls=['P3','P4','P5','P6'];
  if(!lvls.some(function(l){return progress[l]&&progress[l].length;})){toast('Learn a topic first!');return;}
  var txt='MY SCIENCE STARS ⭐\nDate: '+new Date().toLocaleDateString()+'\n\n';
  lvls.forEach(function(l){
    var total=SYL[l].length,done=(progress[l]||[]).length;
    txt+=l+': '+done+'/'+total+'\n';
    if(progress[l]&&progress[l].length)txt+=progress[l].map(function(t){return'  ✓ '+t;}).join('\n')+'\n';
    txt+='\n';
  });
  dlFile(txt,'MyStars.txt');toast('Downloaded! ✅');
}
function dlFile(content,filename){var blob=new Blob([content],{type:'text/plain'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=filename;a.click();URL.revokeObjectURL(a.href);}
function renderStars(){
  var el=document.getElementById('starsOut'),lvls=['P3','P4','P5','P6'];
  if(!lvls.some(function(l){return progress[l]&&progress[l].length;})){el.innerHTML='<div class="emp"><div class="ee">🌱</div><div class="et">Learn a topic to earn stars!</div></div>';return;}
  var html='';
  lvls.forEach(function(l){
    var total=SYL[l].length,done=(progress[l]||[]).length,pct=Math.round(done/total*100);
    html+='<div class="pr"><span class="pl">'+l+'</span><div class="pb"><div class="pf" style="width:'+pct+'%"></div></div><span class="pn">'+done+'/'+total+' ⭐</span></div>';
  });
  html+='<div style="margin-top:12px">';
  lvls.forEach(function(l){if(progress[l]&&progress[l].length)progress[l].forEach(function(t){html+='<span class="dp">'+l+': '+t+'</span>';});});
  html+='</div><div style="margin-top:13px"><button onclick="exportStars()" style="padding:10px 20px;border-radius:11px;border:none;background:#5B4FCF;color:#fff;font-size:12px;font-weight:900;cursor:pointer">📥 Save my stars</button></div>';
  el.innerHTML=html;
}
function toast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2200);}

buildLvls();buildChips();
</script>
</body>
</html>
