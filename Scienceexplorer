<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<title>🔬 Mia &amp; Mochi Science</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;background:#f0eeff;min-height:100vh}
.app{max-width:700px;margin:0 auto;background:#fff;min-height:100vh}
/* HEADER */
.hdr{background:linear-gradient(135deg,#5B4FCF,#7B6FEF);padding:14px 16px;display:flex;align-items:center;gap:12px}
.hdr-icon{width:46px;height:46px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
.hdr h1{color:#fff;font-size:17px;font-weight:900;line-height:1.2}
.hdr p{color:rgba(255,255,255,.75);font-size:11px;margin-top:2px;font-weight:600}
/* TABS */
.tabs{display:flex;background:#ede9ff;border-bottom:3px solid #c9c2f0;overflow-x:auto}
.tb{flex-shrink:0;padding:10px 13px;font-size:12px;font-weight:900;border:none;background:transparent;cursor:pointer;color:#9087c9;border-bottom:3px solid transparent;white-space:nowrap;margin-bottom:-3px}
.tb.on{color:#5B4FCF;border-bottom-color:#5B4FCF;background:#fff}
.tc{display:none;padding:14px}.tc.on{display:block}
/* LEVEL + TOPIC */
.lbl{font-size:10px;font-weight:900;color:#9087c9;text-transform:uppercase;letter-spacing:1.5px;margin:12px 0 8px}
.lbl:first-child{margin-top:0}
.lvl-row{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.lvl-btn{padding:10px 22px;border-radius:30px;border:3px solid #d5ceff;background:#fff;font-size:16px;font-weight:900;color:#9087c9;cursor:pointer}
.lvl-btn.on{background:#5B4FCF;border-color:#5B4FCF;color:#fff;box-shadow:0 4px 12px rgba(91,79,207,.3)}
.topic-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;margin-bottom:14px}
.topic-card{border:3px solid #e8e4ff;border-radius:14px;padding:14px 10px;cursor:pointer;text-align:center;background:#fff}
.topic-card.on{border-color:#5B4FCF;background:#ede9ff}
.topic-card .t-em{font-size:36px;display:block;margin-bottom:6px}
.topic-card .t-nm{font-size:12px;font-weight:900;color:#333;line-height:1.3}
.go-btn{width:100%;padding:14px;border-radius:14px;border:none;background:#5B4FCF;color:#fff;font-size:17px;font-weight:900;cursor:pointer;box-shadow:0 4px 14px rgba(91,79,207,.35)}
.go-btn:disabled{background:#ddd;color:#bbb;box-shadow:none}
/* ── LESSON BLOCKS ── */
.banner{border-radius:16px;padding:18px 16px;margin:14px 0 12px;text-align:center}
.banner .b-em{font-size:46px;margin-bottom:7px;display:block}
.banner .b-lbl{font-size:9px;font-weight:900;letter-spacing:2px;text-transform:uppercase;opacity:.72;margin-bottom:6px}
.banner .b-txt{font-size:17px;font-weight:900;line-height:1.4}
.bp{background:linear-gradient(135deg,#5B4FCF,#7B6FEF);color:#fff}
.bg{background:linear-gradient(135deg,#0F8C63,#1DB983);color:#fff}
.bo{background:linear-gradient(135deg,#CC7A00,#F09B20);color:#fff}
.bb{background:linear-gradient(135deg,#1557A8,#2E7FD4);color:#fff}
.stitle{font-size:12px;font-weight:900;color:#5B4FCF;margin:14px 0 8px;display:flex;align-items:center;gap:7px}
.stitle::after{content:'';flex:1;height:3px;background:#e8e4ff;border-radius:3px}
/* CARD GRID */
.cg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:11px}
.cv{border-radius:13px;padding:13px 11px;text-align:center}
.cv .e{font-size:33px;margin-bottom:6px;display:block}
.cv .t{font-size:12px;font-weight:900;color:#fff;margin-bottom:3px;line-height:1.3}
.cv .s{font-size:10px;font-weight:700;color:rgba(255,255,255,.88);line-height:1.5}
.cp{background:#5B4FCF}.cg2{background:#0F8C63}.co{background:#D47800}.cb{background:#1F6DC5}
.cr{background:#C0392B}.ct{background:#0E7566}.cpk{background:#B5366A}
/* FLOW */
.flow{background:#f4f1ff;border-radius:14px;padding:12px 10px;margin:9px 0 12px;display:flex;align-items:center;flex-wrap:wrap;gap:4px;justify-content:center}
.fb{text-align:center;background:#fff;border-radius:11px;padding:9px 8px;min-width:62px;max-width:82px;border:2.5px solid #d5ceff}
.fb .fe{font-size:26px;margin-bottom:3px;display:block}
.fb .fw{font-size:9px;font-weight:900;color:#5B4FCF;line-height:1.3}
.fa{font-size:20px;color:#b3a8f0;font-weight:900;flex-shrink:0}
.fp{border-color:#5B4FCF;background:#ede9ff}.fg{border-color:#0F8C63;background:#ddf5ec}
.fo{border-color:#D47800;background:#fff3da}.fbb{border-color:#1F6DC5;background:#deeeff}
.fr{border-color:#C0392B;background:#fce9e8}.ft{border-color:#0E7566;background:#d9f3f0}
/* COMPARE */
.cmp{display:flex;align-items:stretch;gap:9px;margin:9px 0 12px}
.cs{flex:1;border-radius:13px;padding:13px 11px;text-align:center}
.cs .ce{font-size:38px;margin-bottom:6px;display:block}
.cs .ct2{font-size:12px;font-weight:900;margin-bottom:6px;line-height:1.3}
.cs .cb2{font-size:11px;font-weight:700;line-height:1.65}
.cL{background:#E1F5EE;border:3px solid #1D9E75}.cL .ct2{color:#0A5C41}.cL .cb2{color:#04342C}
.cR{background:#FFF0DA;border:3px solid #D47800}.cR .ct2{color:#7A3F00}.cR .cb2{color:#5C2E00}
.cvs{display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:#b3a8f0;flex-shrink:0;width:22px}
/* YES/NO */
.yn{margin:7px 0 12px}
.yr{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:11px;margin-bottom:5px}
.ye{font-size:22px;flex-shrink:0;width:30px;text-align:center}
.yn2{flex:1;font-size:12px;font-weight:900;color:#333}
.yb{padding:4px 12px;border-radius:18px;font-size:11px;font-weight:900;flex-shrink:0}
.yy{background:#E1F5EE}.yy .yb{background:#0F8C63;color:#fff}
.yn3{background:#FCEBEB}.yn3 .yb{background:#C0392B;color:#fff}
/* TABLE */
.vt{width:100%;border-collapse:collapse;margin:7px 0 12px;font-size:11px}
.vt th{background:#5B4FCF;color:#fff;padding:8px 9px;font-size:10px;font-weight:900;text-align:left}
.vt td{padding:8px 9px;border-bottom:2px solid #f0eeff;vertical-align:middle;line-height:1.5;font-weight:700;color:#333}
.vt tr:nth-child(even) td{background:#f8f6ff}
.vt td:first-child{font-weight:900;color:#5B4FCF}
/* MEMORY */
.mem{display:flex;gap:11px;align-items:flex-start;background:#FFF0DA;border-radius:13px;padding:13px 15px;margin:9px 0 12px;border-left:5px solid #D47800}
.me{font-size:28px;flex-shrink:0}
.mt{font-size:12px;font-weight:900;color:#5C2E00;line-height:1.6;font-style:italic}
/* SCENE */
.scene{background:#deeeff;border-radius:13px;padding:13px 15px;margin:9px 0 12px;border-left:5px solid #1F6DC5}
.sl{font-size:9px;font-weight:900;color:#1557A8;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px}
.st2{font-size:12px;font-weight:800;color:#0A2D5C;line-height:1.75}
/* STEPS */
.steps{margin:7px 0 12px}
.sr{display:flex;gap:11px;align-items:flex-start;margin-bottom:10px}
.sn{width:30px;height:30px;border-radius:50%;background:#5B4FCF;color:#fff;font-size:13px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.si{font-size:22px;display:block;margin-bottom:1px}
.st3{font-size:12px;font-weight:800;color:#333;line-height:1.55}
/* KEYWORDS + QUIZ */
.kwr{display:flex;gap:5px;flex-wrap:wrap;margin:5px 0 14px}
.kw{padding:4px 11px;border-radius:18px;background:#ede9ff;color:#5B4FCF;font-size:10px;font-weight:900;border:2px solid #c9c2f0}
.qq{background:#f8f6ff;border-radius:12px;padding:13px;margin-bottom:10px;border:2px solid #e8e4ff}
.qqt{font-size:12px;font-weight:900;color:#333;margin-bottom:9px;line-height:1.4}
.qo{padding:10px 13px;border-radius:9px;margin-bottom:5px;border:2.5px solid #d5ceff;font-size:11px;font-weight:800;cursor:pointer;background:#fff;color:#555;text-align:left;width:100%;line-height:1.4}
.qo.ok{background:#0F8C63;border-color:#0F8C63;color:#fff}
.qo.no{background:#C0392B;border-color:#C0392B;color:#fff}
/* ANIMAL GRID */
.ag{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;margin:9px 0 12px}
.ac{border-radius:13px;padding:12px 11px;border:3px solid}
.ac .ae{font-size:32px;margin-bottom:5px;display:block}
.ac .an{font-size:12px;font-weight:900;margin-bottom:6px}
.ac .at{display:inline-block;background:rgba(0,0,0,.07);border-radius:5px;padding:2px 6px;margin:2px 2px 2px 0;font-size:9px;font-weight:900;color:#333}
.ac .aex{font-size:10px;font-weight:800;color:#555;margin-top:5px;line-height:1.5}
/* MAGNET CARDS */
.mg{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;margin:9px 0 12px}
.mc{border-radius:13px;padding:13px 11px;text-align:center;border:3px solid #d5ceff;background:#f8f6ff}
.mc .mce{font-size:40px;margin-bottom:5px;display:block}
.mc .mcn{font-size:12px;font-weight:900;color:#5B4FCF;margin-bottom:5px}
.mc .mcd{font-size:10px;font-weight:700;color:#555;line-height:1.5}
.mc .mcu{display:inline-block;margin-top:7px;padding:3px 9px;border-radius:9px;background:#5B4FCF;color:#fff;font-size:9px;font-weight:900}
/* EXPORT + NOTES */
.el{display:flex;flex-direction:column;gap:9px}
.eb{display:flex;align-items:center;gap:12px;padding:14px;border-radius:13px;border:3px solid #e8e4ff;background:#f8f6ff;cursor:pointer;text-align:left;width:100%}
.eb:active{background:#ede9ff;border-color:#5B4FCF}
.ebi{font-size:28px;flex-shrink:0}
.ebt{font-size:13px;font-weight:900;color:#333}
.ebs{font-size:10px;font-weight:700;color:#aaa;margin-top:1px}
.uz{border:3px dashed #c9c2f0;border-radius:14px;padding:24px;text-align:center;cursor:pointer;background:#f8f6ff;margin-bottom:11px}
.uze{font-size:40px;margin-bottom:7px;display:block}
.uzh{font-size:14px;font-weight:900;color:#333;margin-bottom:2px}
.uzs{font-size:11px;font-weight:700;color:#aaa}
.nta{width:100%;min-height:75px;padding:11px 13px;border-radius:12px;border:2.5px solid #d5ceff;font-size:12px;font-weight:700;color:#333;resize:vertical;line-height:1.6;font-family:inherit}
.nta:focus{outline:none;border-color:#5B4FCF}
.ri{display:flex;gap:7px;margin:8px 0 12px;flex-wrap:wrap;align-items:center}
.ri input{padding:9px 12px;border-radius:10px;border:2.5px solid #d5ceff;font-size:11px;font-weight:800;color:#333;background:#fff}
.ri input:focus{outline:none;border-color:#5B4FCF}
.sv{padding:9px 18px;border-radius:10px;border:none;background:#5B4FCF;color:#fff;font-size:12px;font-weight:900;cursor:pointer}
.nc{background:#f8f6ff;border-radius:12px;padding:12px;margin-bottom:7px;border:2.5px solid #e8e4ff}
.nt{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px}
.ntl{font-size:11px;font-weight:900;color:#5B4FCF}
.nd{padding:3px 9px;border-radius:7px;border:2px solid #d5ceff;background:#fff;cursor:pointer;font-size:10px;font-weight:900;color:#aaa}
.nb{font-size:11px;font-weight:700;color:#666;line-height:1.55}
/* PROGRESS */
.pr{display:flex;align-items:center;gap:10px;margin-bottom:9px}
.pl{font-size:14px;font-weight:900;color:#5B4FCF;width:36px}
.pb{flex:1;height:13px;background:#e8e4ff;border-radius:6px;overflow:hidden}
.pf{height:100%;background:linear-gradient(90deg,#5B4FCF,#7B6FEF);border-radius:6px}
.pn{font-size:11px;font-weight:900;color:#9087c9;width:42px;text-align:right}
.dp{display:inline-block;padding:4px 10px;border-radius:18px;font-size:10px;background:#E1F5EE;color:#0A5C41;margin:3px;font-weight:900;border:2px solid #8FD9BC}
/* ASK */
.ar{display:flex;gap:8px;margin-bottom:10px}
.ar input{flex:1;padding:11px 14px;border-radius:12px;border:2.5px solid #d5ceff;font-size:12px;font-weight:800;color:#333}
.ar input:focus{outline:none;border-color:#5B4FCF}
.ar button{padding:11px 18px;border-radius:12px;border:none;background:#0F8C63;color:#fff;font-size:13px;font-weight:900;cursor:pointer;flex-shrink:0}
.chip{padding:6px 12px;border-radius:18px;border:2.5px solid #d5ceff;font-size:10px;font-weight:900;cursor:pointer;background:#f8f6ff;color:#5B4FCF;margin-bottom:5px;display:inline-block}
.chiprow{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
/* EMPTY */
.emp{text-align:center;padding:36px 16px;color:#ccc}
.emp .ee{font-size:46px;margin-bottom:9px}
.emp .et{font-size:14px;font-weight:900}
/* TOAST */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:11px 22px;border-radius:24px;font-size:12px;font-weight:900;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap}
.toast.show{opacity:1}
</style>
</head>
<body>
<div class="app">
<div class="hdr">
  <div class="hdr-icon">🔬</div>
  <div>
    <h1>Mia &amp; Mochi Science! 🌟</h1>
    <p>Singapore MOE · P3 to P6 · Learn with pictures</p>
  </div>
</div>
<div class="tabs">
  <button class="tb on" onclick="sw('learn')">🎨 Learn</button>
  <button class="tb" onclick="sw('ask')">💬 Ask</button>
  <button class="tb" onclick="sw('notes')">📂 Notes</button>
  <button class="tb" onclick="sw('export')">📤 Export</button>
  <button class="tb" onclick="sw('stars')">⭐ Stars</button>
</div>

<div id="tlearn" class="tc on">
  <div class="lbl">Pick your level 👇</div>
  <div class="lvl-row" id="lvlRow"></div>
  <div id="topSec" style="display:none">
    <div class="lbl">Pick a topic 👇</div>
    <div class="topic-grid" id="topGrid"></div>
  </div>
  <button class="go-btn" id="goBtn" disabled onclick="showLesson()">✨ Show me!</button>
  <div id="lessonOut" style="margin-top:14px"></div>
</div>

<div id="task" class="tc">
  <div class="lbl">What do you want to know? 🤔</div>
  <div class="ar"><input id="qin" type="text" placeholder="Type your question..." onkeydown="if(event.key==='Enter')doAsk()"/><button onclick="doAsk()">Ask! ✨</button></div>
  <div class="lbl">Try these 👇</div>
  <div class="chiprow" id="chips"></div>
  <div id="qaOut"><div class="emp"><div class="ee">🌟</div><div class="et">Ask me anything!</div></div></div>
</div>

<div id="tnotes" class="tc">
  <div class="lbl">Upload a photo 📸</div>
  <div class="uz" onclick="document.getElementById('fIn').click()"><span class="uze">📄</span><div class="uzh">Tap to upload!</div><div class="uzs">Photo or text file · Max 5MB</div></div>
  <input type="file" id="fIn" style="display:none" accept=".txt,.png,.jpg,.jpeg" onchange="onFile(event)"/>
  <div id="fList"></div>
  <div id="fPreview" style="display:none"><div class="lbl">Uploaded 👆</div><div id="fContent"></div></div>
  <div class="lbl" style="margin-top:12px">Write notes ✏️</div>
  <textarea class="nta" id="nta" placeholder="Write notes here..."></textarea>
  <div class="ri">
    <input id="nLvl" placeholder="Level e.g. P4" style="width:90px"/>
    <input id="nTopic" placeholder="Topic e.g. Light" style="flex:1;min-width:100px"/>
    <button class="sv" onclick="saveNote()">💾 Save</button>
  </div>
  <div class="lbl">Saved notes 📝</div>
  <div id="nList"><div class="emp" style="padding:14px 0"><div class="ee" style="font-size:36px">📝</div><div class="et" style="font-size:12px">No notes yet!</div></div></div>
</div>

<div id="texport" class="tc">
  <div class="lbl">Save &amp; Share 📤</div>
  <div class="el">
    <button class="eb" onclick="copyLesson()"><span class="ebi">📋</span><div><div class="ebt">Copy lesson</div><div class="ebs">Paste into WhatsApp or Notes</div></div></button>
    <button class="eb" onclick="exportNotes()"><span class="ebi">📝</span><div><div class="ebt">Save my notes</div><div class="ebs">Download as a file</div></div></button>
    <button class="eb" onclick="exportStars()"><span class="ebi">⭐</span><div><div class="ebt">Save my stars</div><div class="ebs">Download progress report</div></div></button>
    <button class="eb" onclick="window.print()"><span class="ebi">🖨️</span><div><div class="ebt">Print or save PDF</div><div class="ebs">Opens print menu</div></div></button>
  </div>
  <div class="lbl" style="margin-top:18px">Add to home screen 📱</div>
  <div style="background:#f8f6ff;border-radius:14px;padding:16px;border:3px solid #e8e4ff">
    <div style="font-size:14px;font-weight:900;color:#5B4FCF;margin-bottom:5px">📱 iPhone</div>
    <div style="font-size:12px;font-weight:700;color:#555;line-height:1.7;margin-bottom:12px">Safari → Share → <strong>Add to Home Screen</strong></div>
    <div style="font-size:14px;font-weight:900;color:#5B4FCF;margin-bottom:5px">🤖 Android</div>
    <div style="font-size:12px;font-weight:700;color:#555;line-height:1.7">Chrome → ⋮ → <strong>Add to Home Screen</strong></div>
  </div>
</div>

<div id="tstars" class="tc">
  <div class="lbl">My stars ⭐</div>
  <div id="starsOut"><div class="emp"><div class="ee">🌱</div><div class="et">Learn a topic to earn stars!</div></div></div>
</div>
</div>
<div class="toast" id="toast"></div>

<script>
/* ── TINY HELPERS ── */
function B(em,txt,cl){return'<div class="banner '+(cl||'bp')+'"><span class="b-em">'+em+'</span><div class="b-lbl">Big idea ⭐</div><div class="b-txt">'+txt+'</div></div>';}
function ST(t){return'<div class="stitle">'+t+'</div>';}
function CG(arr){return'<div class="cg">'+arr.join('')+'</div>';}
function CV(em,t,s,cl){return'<div class="cv '+(cl||'cp')+'"><span class="e">'+em+'</span><div class="t">'+t+'</div><div class="s">'+s+'</div></div>';}
function FL(boxes){return'<div class="flow">'+boxes.map(function(b,i){return'<div class="fb '+(b.c||'')+'"><span class="fe">'+b.em+'</span><div class="fw">'+b.w+'</div></div>'+(i<boxes.length-1?'<span class="fa">→</span>':'');}).join('')+'</div>';}
function CMP(L,R){return'<div class="cmp"><div class="cs cL"><span class="ce">'+L.em+'</span><div class="ct2">'+L.t+'</div><div class="cb2">'+L.b+'</div></div><div class="cvs">VS</div><div class="cs cR"><span class="ce">'+R.em+'</span><div class="ct2">'+R.t+'</div><div class="cb2">'+R.b+'</div></div></div>';}
function YN(rows){return'<div class="yn">'+rows.map(function(r){return'<div class="yr '+(r.y?'yy':'yn3')+'"><span class="ye">'+r.em+'</span><span class="yn2">'+r.n+'</span><span class="yb">'+(r.y?'✅ YES':'❌ NO')+'</span></div>';}).join('')+'</div>';}
function TBL(hds,rows){return'<table class="vt"><tr>'+hds.map(function(h){return'<th>'+h+'</th>';}).join('')+'</tr>'+rows.map(function(r){return'<tr>'+r.map(function(c){return'<td>'+c+'</td>';}).join('')+'</tr>';}).join('')+'</table>';}
function MEM(em,t,bg,bc,tc){return'<div class="mem" style="background:'+(bg||'#FFF0DA')+';border-left-color:'+(bc||'#D47800')+'"><div class="me">'+em+'</div><div class="mt" style="color:'+(tc||'#5C2E00')+'">'+t+'</div></div>';}
function SC(txt,lbl){return'<div class="scene"><div class="sl">'+(lbl||'🎨 Picture this!')+'</div><div class="st2">'+txt+'</div></div>';}
function STP(arr){return'<div class="steps">'+arr.map(function(s,i){return'<div class="sr"><div class="sn">'+(i+1)+'</div><div><span class="si">'+s.em+'</span><div class="st3">'+s.t+'</div></div></div>';}).join('')+'</div>';}
function KW(arr){return'<div class="kwr">'+arr.map(function(k){return'<span class="kw">'+k+'</span>';}).join('')+'</div>';}
function QZ(qs){return qs.map(function(q,qi){return'<div class="qq"><div class="qqt">'+(qi+1)+'. '+q.q+'</div>'+q.opts.map(function(o,oi){var l=['A','B','C'][oi],ok=q.ans===l;return'<button class="qo" data-ok="'+ok+'" onclick="revQ(this,'+ok+')">'+o+'</button>';}).join('')+'</div>';}).join('');}
